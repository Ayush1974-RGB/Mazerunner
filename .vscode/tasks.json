{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Maze",
      "type": "shell",
      "command": "g++",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\maze.exe",
        "-IC:/SFML-2.5.1/include",
        "-LC:/SFML-2.5.1/lib",
        "-lsfml-graphics",
        "-lsfml-window",
        "-lsfml-system",
        "-mwindows"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    }
  ]
}
